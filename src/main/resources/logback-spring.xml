<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 控制台输出 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- RSSHub 相关日志单独输出 -->
    <appender name="RSSHUB_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/rsshub.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/rsshub.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 设置 RSSHub 相关类的日志级别 -->
    <logger name="com.policyradar.source.rsshub" level="DEBUG" additivity="true">
        <appender-ref ref="RSSHUB_FILE"/>
    </logger>
    <logger name="com.policyradar.observer" level="DEBUG" additivity="true">
        <appender-ref ref="RSSHUB_FILE"/>
    </logger>
    <logger name="com.policyradar.service" level="DEBUG" additivity="true"/>

    <!-- 根日志级别 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
